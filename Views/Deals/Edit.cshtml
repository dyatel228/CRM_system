@model CRM.Web.Models.Deal
@{
    ViewData["Title"] = "Редактирование сделки";
    Layout = "_Layout";
}

<div class="container">
    <div class="form-container">
        <h1 class="form-title">
            <i class="fas fa-handshake"></i> @ViewData["Title"]
        </h1>

        <form method="post" action="/Deals/Edit/@Model.Id">
            <input type="hidden" name="Id" value="@Model.Id">

            <div class="form-group">
                <label class="form-label required">Название сделки</label>
                <input type="text" class="form-control" name="DealName" value="@Model.DealName" required>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label required">Клиент</label>
                        <select class="form-select" name="ClientId" required>
                            <option value="">Выберите клиента</option>
                            @if (ViewBag.Clients != null)
                            {
                                foreach (var client in ViewBag.Clients)
                                {
                                    <option value="@client.Id" selected="@(client.Id == Model.ClientId)">@client.CompanyName</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Ответственный менеджер</label>
                        <select class="form-select" name="ResponsibleUserId">
                            <option value="">Не назначен</option>
                            @if (ViewBag.Users != null)
                            {
                                foreach (var user in ViewBag.Users)
                                {
                                    <option value="@user.Id" selected="@(user.Id == Model.ResponsibleUserId)">@user.LastName @user.FirstName</option>
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label required">Сумма (₽)</label>
                        <input type="number" step="0.01" min="0" class="form-control" name="Amount" value="@Model.Amount" required>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label">Стадия</label>
                        <select class="form-select" name="Stage">
                            <option value="Переговоры" selected="@(Model.Stage == "Переговоры")">Переговоры</option>
                            <option value="Оформление" selected="@(Model.Stage == "Оформление")">Оформление</option>
                            <option value="Закрыта" selected="@(Model.Stage == "Закрыта")">Закрыта</option>
                            <option value="Отменена" selected="@(Model.Stage == "Отменена")">Отменена</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Срок исполнения</label>
                <input type="date" class="form-control" name="DeadlineDate" value="@(Model.DeadlineDate?.ToString("yyyy-MM-dd") ?? "")">
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-warning">
                    <i class="fas fa-save"></i> Сохранить
                </button>
                <a href="/Deals" class="btn btn-outline-secondary">
                    <i class="fas fa-times"></i> Отмена
                </a>
            </div>
        </form>
    </div>
</div>